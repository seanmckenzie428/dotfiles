# ~/.zshrc

# Enable Powerlevel10k instant prompt. Keep near the top.
if [[ -r "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh" ]]; then
  source "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh"
fi

# ---------- Homebrew ----------
export HOMEBREW_PREFIX="${HOMEBREW_PREFIX:-/opt/homebrew}"

# ---------- Prompt ----------
source "${HOMEBREW_PREFIX}/share/powerlevel10k/powerlevel10k.zsh-theme"

[[ -f ~/.p10k.zsh ]] && source ~/.p10k.zsh

# ---------- Helpers ----------
setopt AUTO_CD

{{ if eq .chezmoi.os "darwin" }}
export EDITOR="zed --wait"
export VISUAL="zed --wait"
export SSH_AUTH_SOCK="$HOME/Library/Containers/com.bitwarden.desktop/Data/.bitwarden-ssh-agent.sock"
{{ else }}
export EDITOR="nvim"
{{ end }}

# ---------- Fish-style abbreviations ----------

typeset -A ABBR

abbr() {
  ABBR[$1]="$2"
}

_expand_abbrev() {
  local word
  word=${LBUFFER##*[^[:alnum:]_./:-]}

  if [[ -n "$word" && -n ${ABBR[$word]} ]]; then
    LBUFFER="${LBUFFER%$word}${ABBR[$word]}"
  fi
}

_expand_abbrev_space() {
  _expand_abbrev
  zle self-insert
}

_expand_abbrev_accept() {
  _expand_abbrev
  zle accept-line
}

_expand_abbrev_tab() {
  _expand_abbrev
  zle expand-or-complete
}

zle -N _expand_abbrev_space
zle -N _expand_abbrev_accept
zle -N _expand_abbrev_tab

bindkey " " _expand_abbrev_space
bindkey "^M" _expand_abbrev_accept
bindkey "^I" _expand_abbrev_tab

# ---------- Abbreviations ----------

abbr art "php artisan"
abbr cz "chezmoi"
abbr cza "chezmoi apply"
abbr cze "chezmoi edit"
abbr czr "chezmoi re-add"
abbr dc "docker compose"
abbr dcd "docker compose down"
abbr dcdv "docker compose down -v"
abbr dcu "docker compose up"
abbr dcud "docker compose up -d"
abbr fresh "php artisan migrate:fresh --seed"
abbr ld "lazydocker"
abbr lg "lazygit"
abbr listen "php artisan queue:listen"
abbr migrate "php artisan migrate"
abbr oc "opencode"
abbr pest "./vendor/bin/pest"
abbr pestl "./vendor/bin/pest --parallel"
abbr pint "./vendor/bin/pint"
abbr pintd "./vendor/bin/pint --dirty"
abbr pn pnpm
abbr pnx "pnpm dlx"
abbr sa "./vendor/bin/sail artisan"
abbr sail "./vendor/bin/sail"
abbr samfs "./vendor/bin/sail artisan migrate:fresh --seed"
abbr sc "./vendor/bin/sail composer"
abbr spest "./vendor/bin/sail pest"
abbr spint "./vendor/bin/sail pint"
abbr stan "./vendor/bin/phpstan"
abbr st "speedtest"
abbr stest "./vendor/bin/sail test"
abbr stestl "./vendor/bin/sail test --parallel"
abbr stinker "./vendor/bin/sail artisan tinker"
abbr testl "php artisan test --parallel"
abbr tinker "php artisan tinker"
abbr ts "tailscale"
abbr vim "nvim"
abbr vite "./vendor/bin/sail npm run dev"
abbr work "php artisan queue:work"
abbr wts "wt switch"

{{ if eq .chezmoi.os "darwin" }}
abbr rm "trash"
{{ end }}

# ---------- Aliases ----------
# Keep aliases for things that should work in scripts/functions too.
alias l='eza'
alias ls='eza'
alias la='eza -a'
alias ll='eza -lah'
alias t='tmux a || tmux new'

# ---------- Navigation ----------

setopt AUTO_CD

alias ..="cd .."
alias ...="cd ../.."
alias ....="cd ../../.."

# ---------- Functions ----------

function y() {
	local tmp="$(mktemp -t "yazi-cwd.XXXXXX")" cwd
	command yazi "$@" --cwd-file="$tmp"
	IFS= read -r -d '' cwd < "$tmp"
	[ "$cwd" != "$PWD" ] && [ -d "$cwd" ] && builtin cd -- "$cwd"
	rm -f -- "$tmp"
}

# ---------- Completion ----------

autoload -Uz compinit
compinit

zstyle ':completion:*' menu select
zstyle ':completion:*' matcher-list 'm:{a-z}={A-Za-z}'
zstyle ':completion:*' list-colors "${(s.:.)LS_COLORS}"

# ---------- History ----------

HISTFILE="$HOME/.zsh_history"
HISTSIZE=10000
SAVEHIST=10000

setopt HIST_IGNORE_DUPS
setopt HIST_IGNORE_ALL_DUPS
setopt HIST_FIND_NO_DUPS
setopt SHARE_HISTORY
setopt INC_APPEND_HISTORY
setopt HIST_REDUCE_BLANKS

bindkey '^[[A' up-line-or-search
bindkey '^[[B' down-line-or-search

# ---------- Plugins ----------
source "${HOMEBREW_PREFIX}/share/zsh-autosuggestions/zsh-autosuggestions.zsh"
source "${HOMEBREW_PREFIX}/share/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh"

if command -v fzf >/dev/null 2>&1; then
  source <(fzf --zsh)
fi

if command -v zoxide >/dev/null 2>&1; then
  eval "$(zoxide init zsh)"
fi

if command -v wt >/dev/null 2>&1; then
  eval "$(command wt config shell init zsh)"
fi

{{ if eq .chezmoi.os "linux" }}
# bun completions
[ -s "/home/seanm/.bun/_bun" ] && source "/home/seanm/.bun/_bun"

eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv zsh)"
{{ end }}

# now, simply add these two lines in your ~/.zshrc

# source antidote
source "${HOMEBREW_PREFIX}/opt/antidote/share/antidote/antidote.zsh"

# initialize plugins statically with ${ZDOTDIR:-$HOME}/.zsh_plugins.txt
antidote load

eval "$(mise activate zsh)"
source "$HOME/.completion-for-pnpm.zsh"
