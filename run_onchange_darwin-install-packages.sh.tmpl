{{ if eq .chezmoi.os "darwin" -}}
#!/bin/bash
set -euo pipefail

if ! command -v mise >/dev/null 2>&1; then
  curl https://mise.run | sh
  export PATH="$HOME/.local/bin:$PATH"
fi

mise install \
{{- range .packages.mise }}
  {{ . | quote }} \
{{- end }}

brew bundle --file=/dev/stdin <<EOF
{{ range .packages.darwin.brews -}}
brew {{ . | quote }}
{{ end -}}
{{ range .packages.darwin.casks -}}
cask {{ . | quote }}
{{ end -}}
EOF

{{ range .apps.darwin -}}
mas install {{ . | quote }}
{{ end -}}

{{ end -}}
