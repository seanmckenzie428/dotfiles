# ~/.zprofile
# Login-shell environment

{{ if eq .chezmoi.os "darwin" }}
export EDITOR="zed --wait"
export VISUAL="zed --wait"
export SSH_AUTH_SOCK="$HOME/Library/Containers/com.bitwarden.desktop/Data/.bitwarden-ssh-agent.sock"
{{ else }}
export EDITOR="nvim"
{{ end }}

export BUN_INSTALL="$HOME/.bun"

{{ if eq .chezmoi.os "darwin" }}
# Laravel Herd (macOS only)
export HERD_PHP_83_INI_SCAN_DIR="$HOME/Library/Application Support/Herd/config/php/83/"
export HERD_PHP_84_INI_SCAN_DIR="$HOME/Library/Application Support/Herd/config/php/84/"
export HERD_PHP_85_INI_SCAN_DIR="$HOME/Library/Application Support/Herd/config/php/85/"
{{ end }}

{{ if eq .chezmoi.os "linux" }}
echo >> $HOME/.zshrc
echo 'eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv zsh)"' >> $HOME/.zshrc
eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv zsh)"
{{ end }}

# Deduplicated PATH handling
typeset -U path PATH

path=(
  "$BUN_INSTALL/bin"
  "$HOME/.composer/vendor/bin"
  "$HOME/.local/bin"
{{ if eq .chezmoi.os "darwin" }}
  "$HOME/Library/Application Support/Herd/bin"
  "/Users/Shared/DBngin/mariadb/10.11.6_arm/bin"
  "/Users/Shared/DBngin/postgresql/17.0/bin"
  "/Users/Shared/DBngin/redis/7.0.0/bin"
{{ end }}
  $path
)

export PATH
