// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "cli_default_open_behavior": "new_window",
  "language_models": {
    "opencode": {
      "show_zen_models": false
    }
  },
  "go_to_definition_fallback": "find_all_references",
  "semantic_tokens": "combined",
  "buffer_font_size": 14.0,
  "ssh_connections": [
    {
      "host": "omakase",
      "args": [],
      "projects": [
        {
          "paths": [
            "/home/sean/homelab"
          ]
        }
      ]
    },
    {
      "host": "bmo",
      "args": [],
      "projects": [
        {
          "paths": [
            "/home/bmo/.openclaw"
          ]
        }
      ]
    }
  ],
  "edit_predictions": {
    "allow_data_collection": "no",
    "provider": "copilot",
  },
  "proxy": "",
  "session": {
    "trust_all_worktrees": true,
  },
  "project_panel": {
    "git_status_indicator": true,
    "dock": "left",
  },
  "outline_panel": {
    "dock": "left",
  },
  "collaboration_panel": {
    "button": false,
    "dock": "left",
  },
  "git_panel": {
    "tree_view": true,
    "dock": "left",
  },
  "diff_view_style": "split",
  "disable_ai": false,
  "audio": {
    "experimental.auto_microphone_volume": true,
  },
  "git": {
    "inline_blame": {
      "enabled": true,
      "show_commit_summary": true,
    },
  },
  "tabs": {
    "file_icons": false,
    "git_status": false,
  },
  "debugger": {},
  "search": {
    "center_on_match": true,
  },
  "prettier": {
    "allowed": true,
  },
  "completions": {},
  "vim": {
    "use_smartcase_find": true,
    "use_system_clipboard": "never",
    "toggle_relative_line_numbers": true,
  },
  "which_key": {
    "delay_ms": 500,
    "enabled": true,
  },
  "ui_font_family": ".ZedSans",
  "agent_buffer_font_size": 14.0,
  "agent_servers": {
    "pi-acp": {
      "type": "registry"
    },
    "opencode": {
      "type": "registry",
    },
    "codex-acp": {
      "default_config_options": {
        "mode": "full-access"
      },
      "type": "registry",
    },
  },
  "calls": {
    "mute_on_join": true,
  },
  "agent": {
    "default_profile": "write",
    "profiles": {
      "research": {
        "default_model": {
          "provider": "openai-subscribed",
          "model": "gpt-5.5",
          "enable_thinking": true,
          "effort": "medium"
        },
        "name": "Research",
        "tools": {
          "edit_file": true,
          "update_plan": true,
          "terminal": false,
          "spawn_agent": true,
          "read_file": true,
          "open": true,
          "now": true,
          "list_directory": true,
          "grep": true,
          "go_to_definition": true,
          "get_code_actions": true,
          "find_references": true,
          "find_path": true,
          "fetch": true,
          "diagnostics": true,
          "copy_path": true
        },
        "enable_all_context_servers": false,
        "context_servers": {}
      }
    },
    "tool_permissions": {
      "default": "allow",
      "tools": {}
    },
    "show_turn_stats": true,
    "thinking_display": "always_collapsed",
    "expand_edit_card": false,
    "expand_terminal_card": false,
    "flexible": false,
    "sidebar_side": "left",
    "single_file_review": true,
    "notify_when_agent_waiting": "never",
    "new_thread_location": "new_worktree",
    "dock": "left",
    "use_modifier_to_send": false,
    "play_sound_when_agent_done": "always",
    "enable_feedback": false,
    "default_model": {
      "speed": "standard",
      "provider": "opencode",
      "model": "go/kimi-k2.5",
      "enable_thinking": false,
    },
    "favorite_models": [
      {
        "provider": "openai-subscribed",
        "model": "gpt-5.5",
        "enable_thinking": true,
        "effort": "xhigh",
        "speed": "standard"
      }
    ],
    "model_parameters": [],
  },
  "terminal": {
    "toolbar": {
      "breadcrumbs": false,
    },
    "cursor_shape": "bar",
    "font_size": 13.0,
    "shell": "system",
  },
  "restore_on_startup": "last_session",
  "redact_private_values": false,
  "when_closing_with_no_tabs": "close_window",
  "on_last_window_closed": "quit_app",
  "autosave": "on_focus_change",
  "icon_theme": {
    "mode": "system",
    "light": "Catppuccin Latte",
    "dark": "Catppuccin Mocha",
  },
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },
  "vim_mode": true,
  "base_keymap": "JetBrains",
  "ui_font_size": 16.0,
  "theme": {
    "mode": "dark",
    "light": "JetBrains Light",
    "dark": "JetBrains Dark",
  },
  "languages": {
    "PHP": {
      "language_servers": ["intelephense", "!phpactor", "!phptools", "..."],
    },
  },
  "lsp": {
    "tailwindcss-language-server": {
      "settings": {
        "includeLanguages": {
          "php": "html",
          "blade": "html",
        },
        "experimental": {
          "classRegex": [
            "class=\"([^\"]*)\"",
            "class='([^']*)'",
            "class=\\\"([^\\\"]*)\\\"",
            "@class\\(\\[([^\\]]*)\\]\\)",
            "\\.className\\s*[+]?=\\s*['\"]([^'\"]*)['\"]",
            "\\.setAttributeNS\\(.*,\\s*['\"]class['\"],\\s*['\"]([^'\"]*)['\"]",
            "\\.setAttribute\\(['\"]class['\"],\\s*['\"]([^'\"]*)['\"]",
            "\\.classList\\.add\\(['\"]([^'\"]*)['\"]",
            "\\.classList\\.remove\\(['\"]([^'\"]*)['\"]",
            "\\.classList\\.toggle\\(['\"]([^'\"]*)['\"]",
            "\\.classList\\.contains\\(['\"]([^'\"]*)['\"]",
            "\\.classList\\.replace\\(\\s*['\"]([^'\"]*)['\"]",
            "\\.classList\\.replace\\([^,)]+,\\s*['\"]([^'\"]*)['\"]",
          ],
        },
      },
    },
    "eslint": {
      "settings": {
        "onIgnoredFiles": "off",
      },
    },
  },
}
