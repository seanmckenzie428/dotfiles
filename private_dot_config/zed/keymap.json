// Zed keymap
//
// For information on binding keys, see the Zed
// documentation: https://zed.dev/docs/key-bindings
//
// To see the default key bindings run `zed: open default keymap`
// from the command palette.
[
  {
    "context": "Workspace",
    "bindings": {
      // "shift shift": "file_finder::Toggle"
    },
  },
  {
    "context": "Editor && vim_mode == insert",
    "bindings": {
      // "j k": "vim::NormalBefore"
    },
  },
  {
    "context": "Workspace",
    "unbind": {
      "cmd-k": "git_panel::ToggleFocus",
    },
  },
  {
    "context": "Picker > Editor",
    "unbind": {
      "ctrl-h": "editor::Backspace",
    },
  },
  {
    "context": "vim_mode == literal",
    "unbind": {
      "ctrl-h": ["vim::Literal", ["ctrl-h", "\b"]],
    },
  },
  {
    "context": "Editor",
    "unbind": {
      "ctrl-h": "editor::Backspace",
    },
  },
  {
    "context": "vim_mode == literal",
    "unbind": {
      "ctrl-l": ["vim::Literal", ["ctrl-l", "\f"]],
    },
  },
  {
    "context": "Editor",
    "unbind": {
      "ctrl-l": "editor::ScrollCursorCenter",
    },
  },
  {
    "bindings": {
      "ctrl-h": "workspace::ActivatePaneLeft",
      "ctrl-l": "workspace::ActivatePaneRight",
      "ctrl-k": "workspace::ActivatePaneUp",
      "ctrl-j": "workspace::ActivatePaneDown",
    },
  },
  {
    "bindings": {
      "cmd-2": "git_panel::ToggleFocus"
    }
  },
  {
    "context": "GitPanel",
    "bindings": {
      "cmd-2": "workspace::CloseActiveDock"
    }
  },
  {
    "context": "Workspace",
    "unbind": {
      "cmd-3": [
        "workspace::ActivatePane",
        2
      ]
    }
  },
  {
    "context": "Welcome",
    "unbind": {
      "cmd-3": [
        "welcome::OpenRecentProject",
        2
      ]
    }
  },
  {
    "context": "RunModal",
    "unbind": {
      "cmd-3": "new_process_modal::ActivateAttachTab"
    }
  },
  {
    "bindings": {
      "cmd-3": "agent::ToggleFocus"
    }
  },
  {
    "context": "AgentPanel",
    "bindings": {
      "cmd-3": "workspace::CloseActiveDock"
    }
  },
  {
    "bindings": {
      "cmd-4": "multi_workspace::ToggleWorkspaceSidebar"
    }
  },
  {
    "bindings": {
      "f12": "terminal_panel::Toggle"
    }
  },
  {
    "context": "Workspace",
    "bindings": {
      "cmd-o": "file_finder::Toggle"
    }
  },
  {
    "unbind": {
      "cmd-o": "workspace::Open"
    }
  }
]
