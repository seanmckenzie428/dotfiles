{{ if eq .chezmoi.os "linux" -}}
#!/usr/bin/env bash
set -euo pipefail

if ! command -v pacman >/dev/null 2>&1; then
  echo "pacman not found; skipping Arch package install"
  exit 0
fi

sudo pacman -Syu --needed --noconfirm \
{{- range .packages.arch.pacman }}
  {{ . | quote }} \
{{- end }}

if [ {{ len .packages.arch.aur }} -gt 0 ]; then
  if command -v yay >/dev/null 2>&1; then
    yay -S --needed --noconfirm \
{{- range .packages.arch.aur }}
      {{ . | quote }} \
{{- end }}
  else
    cat >&2 <<'EOF'
AUR packages are configured but no AUR helper was found.

Install yay first, then run:
  chezmoi apply

Configured AUR packages:
{{- range .packages.arch.aur }}
  - {{ . }}
{{- end }}
EOF
  fi
fi

if [ {{ len .packages.arch.bun }} -gt 0 ]; then
  if command -v bun >/dev/null 2>&1; then
    bun add --global \
{{- range .packages.arch.bun }}
      {{ . | quote }} \
{{- end }}
  else
    echo "bun not found; attempting to install bun..."
    if curl -fsSL https://bun.com/install | bash; then
      # Ensure BUN_INSTALL and PATH are set for this shell session (installer normally writes to shell profile)
      export BUN_INSTALL="${BUN_INSTALL:-$HOME/.bun}"
      export PATH="$BUN_INSTALL/bin:$PATH"
      if command -v bun >/dev/null 2>&1; then
        bun add --global \
{{- range .packages.arch.bun }}
          {{ . | quote }} \
{{- end }}
      else
        cat >&2 <<'EOF'
Bun was installed but the bun executable is not available in PATH in this session.

You may need to restart your shell or add Bun to PATH:
  export BUN_INSTALL="$HOME/.bun"
  export PATH="$BUN_INSTALL/bin:$PATH"

Configured bun packages:
{{- range .packages.arch.bun }}
  - {{ . }}
{{- end }}
EOF
      fi
    else
      cat >&2 <<'EOF'
Failed to install Bun via the official installer.

Please install Bun manually with:
  curl -fsSL https://bun.com/install | bash

Configured bun packages:
{{- range .packages.arch.bun }}
  - {{ . }}
{{- end }}
EOF
    fi
  fi
fi
{{ end -}}
