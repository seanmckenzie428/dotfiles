{{ if eq .chezmoi.os "linux" -}}
#!/usr/bin/env bash
set -euo pipefail

if ! command -v pacman >/dev/null 2>&1; then
  echo "pacman not found; skipping Arch package install"
  exit 0
fi

sudo pacman -Syu --needed --noconfirm \
{{- range .packages.arch.pacman }}
  {{ . | quote }} \
{{- end }}

if [ {{ len .packages.arch.aur }} -gt 0 ]; then
  if command -v yay >/dev/null 2>&1; then
    yay -S --needed --noconfirm \
{{- range .packages.arch.aur }}
      {{ . | quote }} \
{{- end }}
  else
    cat >&2 <<'EOF'
AUR packages are configured but no AUR helper was found.

Install yay first, then run:
  chezmoi apply

Configured AUR packages:
{{- range .packages.arch.aur }}
  - {{ . }}
{{- end }}
EOF
  fi
fi
{{ end -}}
